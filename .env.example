APP_NAME=ICTU AI Chatbot
ENVIRONMENT=development
PORT=8000
WEB_CONCURRENCY=1

# Security
PARTNER_API_KEY=change-me-partner-key-min-32-chars
JWT_SECRET=change-me-jwt-secret-min-32-chars
SESSION_SECRET=change-me-session-secret-min-32-chars
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=change-me-admin-password-min-12-chars
ADMIN_ROLE=admin
USER_USERNAME=student
USER_PASSWORD=change-me-user-password-min-12-chars
USER_ROLE=user

# Optional legacy provider
GEMINI_API_KEY=

# CORS
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# Runtime chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Rate limiting
API_RATE_CHAT=100/minute
API_RATE_UPLOAD=10/hour
API_RATE_ADMIN=10/minute

# Paths (relative paths are resolved from the project root)
DATA_DIR=data
LOG_DIR=logs
UPLOAD_DIR=data/uploads
RAG_UPLOAD_ROOT=data/rag_uploads
DB_PATH=data/bot_config.db
QA_CORPUS_ROOT=data/primary_corpus
VECTORSTORE_DIR=vectorstore
API_LOG_PATH=logs/api.log
SYSTEM_PROMPT_PATH=data/systemprompt.md
BOT_RULE_PATH=data/bot-rule.md
INTENTS_DIR=data/intents
BADWORDS_PATH=data/badwords.md
FRONTEND_TEMPLATE_DIR=views/frontend/templates
FRONTEND_ASSET_DIR=views/frontend/assets

# Azure App Service demo path example:
# DATA_DIR=/home/site/data
# LOG_DIR=/home/LogFiles
# UPLOAD_DIR=/home/site/data/uploads
# RAG_UPLOAD_ROOT=/home/site/data/rag_uploads
# DB_PATH=/home/site/data/bot_config.db
# VECTORSTORE_DIR=/home/site/vectorstore
# API_LOG_PATH=/home/LogFiles/api.log
# HF_HOME=/home/site/hf-cache

# Web search
SEARXNG_URL=
SEARXNG_API=
TRAFILATURA_URL=
TRAFILATURA_API=
WEB_KB_TRUSTED_THRESHOLD=30
WEB_KB_MIN_SCORE=18
WEB_KB_TTL_DAYS=30
WEB_KB_REALTIME_TTL_DAYS=2

# LLM configuration
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_PROVIDER_ORDER=groq
LLM_MODEL_ROTATION=round_robin
GROQ_MODEL_ORDER=llama-3.1-8b-instant,llama-3.3-70b-versatile,openai/gpt-oss-20b,openai/gpt-oss-120b,qwen/qwen3-32b,meta-llama/llama-4-scout-17b-16e-instruct
OLLAMA_MODEL_ORDER=llama3.1:8b

# Optional providers and production services. These are placeholders until the
# codebase is migrated away from local SQLite/local file storage.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
DATABASE_URL=
REDIS_URL=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=knowledge-docs
