SECRET_KEY=your-secret-key-here
APP_ENV=development
APP_DEBUG=1
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
UVICORN_RELOAD=0
SESSION_HTTPS_ONLY=0
SESSION_SAME_SITE=lax

# SQLite DB for chat history
CHAT_DB_NAME=chat.db

# Source and generated data folders
RAW_DATA_DIR=datadoan
CLEAN_MD_DIR=clean_md
RAG_MD_DIR=rag_md
TXT_DATA_DIR=data
VECTOR_DB_DIR=vector_db

# Upload settings
UPLOADS_DIR_NAME=_uploads
MAX_UPLOAD_SIZE_MB=25

# LLM provider: ollama, gemini or auto
LLM_PROVIDER=auto

# Ollama
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Embeddings
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional neural reranker
ENABLE_NEURAL_RERANKER=0
NEURAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
