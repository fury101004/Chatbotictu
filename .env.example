FLASK_SECRET_KEY=your-secret-key-here
FLASK_DEBUG=1
FLASK_USE_RELOADER=0

# SQLite DB cho lịch sử chat (mặc định chat.db trong thư mục dự án)
CHAT_DB_NAME=E:\datadoantn\chat.db

# Dữ liệu nguồn PDF/DOCX
RAW_DATA_DIR=E:\datadoantn\datadoan

# Markdown sạch sau khi chạy clean_data_to_md.py
CLEAN_MD_DIR=E:\datadoantn\clean_md

# Markdown tối ưu cho chunk/RAG (tạo từ clean_md)
RAG_MD_DIR=E:\datadoantn\rag_md

# Dữ liệu txt (nếu có)
TXT_DATA_DIR=E:\datadoantn\data

# Thư mục lưu FAISS vector DB
VECTOR_DB_DIR=E:\datadoantn\vector_db

# Cấu hình Ollama
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3

# Model embeddings cho LangChain
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Neural reranker dung sentence-transformers/torch.
# Mac dinh de 0 de tranh loi DLL tren Windows, bat len khi moi truong on dinh.
ENABLE_NEURAL_RERANKER=0
NEURAL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

